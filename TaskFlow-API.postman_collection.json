{
  "info": {
    "_postman_id": "taskflow-api-v1",
    "name": "TaskFlow API v1",
    "description": "Complete API collection for the TaskFlow Task Management application.\n\nSetup:\n1. Import this collection into Postman.\n2. Set the `base_url` collection variable to your server URL (default: http://localhost:3000).\n3. Run 'Register User' or 'Login User' first — the token is saved automatically.\n4. All authenticated requests use the saved token via the collection-level Authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "  console.log('Token saved:', body.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new USER account. Returns JWT token."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "  console.log('Token saved:', body.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login and receive a JWT token."
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskflow.dev\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as the seeded admin user."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get Tasks",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "", "disabled": true }
              ]
            },
            "description": "Get paginated list of the authenticated user's tasks. Supports ?search= and ?page= ?limit= query params."
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('task_id', body.data.id);",
                  "  console.log('Task ID saved:', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Set up CI/CD pipeline\",\n  \"description\": \"Configure GitHub Actions for automated testing and deployment.\",\n  \"status\": \"PENDING\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"]
            },
            "description": "Create a new task. Status defaults to PENDING."
          }
        },
        {
          "name": "Update Task",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"title\": \"Set up CI/CD pipeline (updated)\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            },
            "description": "Update task title, description, or status. Only owners can update."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            },
            "description": "Delete a task. Only the owner (or ADMIN) can delete."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin — Get All Users",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users"]
            },
            "description": "ADMIN ONLY — Get all registered users (passwords excluded)."
          }
        },
        {
          "name": "Admin — Get All Tasks",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/admin/tasks?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "ADMIN ONLY — Get all tasks across all users, with user info joined."
          }
        }
      ]
    }
  ]
}
